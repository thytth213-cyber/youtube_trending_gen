# YouTube Data API (FREE tier)
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenAI / ChatGPT API (ChatGPT Plus subscription)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Google Veo 3 API (Google AI Studio)
GOOGLE_VEO3_API_KEY=your_google_veo3_api_key_here

# Canva API (Canva Pro)
CANVA_API_TOKEN=your_canva_api_token_here

# Buffer API (for social media scheduling)
BUFFER_API_TOKEN=your_buffer_api_token_here

# SendGrid (email reports - free tier)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_RECIPIENT=your@email.com
EMAIL_SENDER=noreply@yourdomain.com

# Reddit API (PRAW - free)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ContentAI/1.0 by YourUsername

# Scheduling configuration
USER_TIMEZONE=UTC
DAILY_RUN_TIME=00:00

# Application environment (dev or prod)
APP_ENV=prod

# Database path (inside container)
DATABASE_URL=sqlite:////app/data/content_ai.db

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Number of videos to generate per day
VIDEOS_PER_DAY=10

# Cost tracking (USD per second for Veo 3 Fast mode)
VEO3_COST_PER_SECOND=0.15
